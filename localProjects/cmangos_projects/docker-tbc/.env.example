# ============================================================================
# CMaNGOS TBC — Environment Variables
# ============================================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env
# ============================================================================

# --- MariaDB ---
MYSQL_ROOT_PASSWORD=mangos_root_password

# --- Server Identity ---
SERVER_PUBLIC_IP=127.0.0.1
REALM_NAME=CMaNGOS TBC

# --- Database Connection (auto-configured, change only if customizing) ---
# DB_HOST=cmangos-tbc-db
# DB_PORT=3306
# DB_USER=mangos
# DB_PASS=mangos
# MANGOS_DB=tbcmangos
# CHARACTERS_DB=tbccharacters
# REALMD_DB=tbcrealmd
# LOGS_DB=tbclogs

# --- Server Configuration Overrides ---
# Mangosd_WorldServerPort=8085
# Mangosd_Ra_Enable=1
# Mangosd_Ra_Port=3443
# Mangosd_SOAP_Enabled=0
# Mangosd_PlayerBot_Enabled=1
# Realmd_MaxSessionDuration=0

# --- Docker Compose ---
# COMPOSE_PROJECT_NAME=cmangos-tbc
# DB_EXTERNAL_PORT=3307
