# ═══════════════════════════════════════════════════════════════
# Drums of War — Main Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Server Public Address ──
# Your domain or IP that players connect to
SERVER_PUBLIC_IP=wow.example.com

# ── Database Root Password ──
# Shared across all MariaDB/MySQL containers
MARIADB_ROOT_PASSWORD=change_me_strong_password_here

# ── Website ──
MW_DOMAIN=world-of-warcraft.example.com
JWT_SECRET=generate_with_openssl_rand_hex_32
RESEND_API_KEY=re_your_resend_api_key
NEXT_PUBLIC_SITE_URL=https://world-of-warcraft.example.com
EMAIL_FROM=Drums of War <noreply@example.com>

# ── Traefik ──
MW_TRAEFIK_CERTRESOLVER=letsencrypt_dns

# ── AzerothCore (WotLK) ──
DOCKER_DB_ROOT_PASSWORD=change_me_strong_password_here
