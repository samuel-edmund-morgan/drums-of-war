# AzerothCore draft stack for Phase 16.1
# Copy to `.env` and adjust as needed.

# Official source checkout used for ARM64-safe local builds.
# Expected checkout command:
#   git clone https://github.com/azerothcore/azerothcore-wotlk ../azerothcore-wotlk
AZEROTHCORE_SRC=../azerothcore-wotlk

# Keep `master` to stay aligned with the official acore-docker defaults.
DOCKER_IMAGE_TAG=master

# Docker user args consumed by the official Dockerfile targets.
DOCKER_USER=acore
DOCKER_USER_ID=1000
DOCKER_GROUP_ID=1000

# External ports reserved after the current Classic/TBC/WotLK stacks.
DOCKER_WORLD_EXTERNAL_PORT=8088
DOCKER_AUTH_EXTERNAL_PORT=3727
DOCKER_SOAP_EXTERNAL_PORT=7879
DOCKER_DB_EXTERNAL_PORT=3309

# Database credentials for the local AzerothCore stack.
DOCKER_DB_ROOT_PASSWORD=change_me

# Optional host bind mounts; empty values fall back to local relative paths.
DOCKER_VOL_ETC=
DOCKER_VOL_LOGS=
DOCKER_VOL_DATA=
DOCKER_VOL_DB=
